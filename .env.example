# Copy this file to .env and fill in your Supabase project values.
# Get these from: Supabase Dashboard → Project Settings → API

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── Edge Function secrets (set via: supabase secrets set KEY=VALUE) ──
# Get GEMINI_API_KEY from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
# CRON_SECRET: any random string you choose, used to authenticate scheduled jobs
CRON_SECRET=your-cron-secret-here
# Get from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
